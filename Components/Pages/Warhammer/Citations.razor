@page "/warhammer/citations"
@using Microsoft.EntityFrameworkCore
@using Sinaf.Me.Data
@using Sinaf.Me.Data.Warhammer

<main>
    <h1>Les citations</h1>
    <p>
        Que ce soit dans les livres, vidéos, jeux ou même juste des gens randoms, certaines phrases
        ou simplement des mots m'ont marqué ou bêtement fait rire. Voici une liste complète de ces
        citations!
    </p>

    <section>
        @foreach (var citation in citations)
        {
            <figure>
                <blockquote>
                    @((MarkupString)citation.Content)
                </blockquote>
                <figcaption>@citation.Source</figcaption>
            </figure>
        }
    </section>
</main>

@code {

    private Citation[] citations = [];
	
    protected override async Task OnInitializedAsync()
    {
        await using var context = new WarhammerDbContext();
        citations = await context.Citations.ToArrayAsync();
    }

}