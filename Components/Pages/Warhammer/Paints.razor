@page "/warhammer/paints"
@using Microsoft.EntityFrameworkCore
@using Sinaf.Me.Data
@using Sinaf.Me.Data.Warhammer
<main>
    <h1>Mes peintures</h1>

    <section>
        @foreach (var paint in paints)
        {
            <article>
                <div style="background: @("#" + paint.Hex);">
                
                </div>
                <div>
                    <h3>@paint.Name</h3>
                    <span>@paint.Type.Name</span>
                    @if (paint.SubTypeId != 1)
                    {
                        <span>@paint.SubType.Name</span>
                    }
                </div>
            </article>
        }
    </section>
</main>

@code {

    private Paint[] paints = [];

    protected override async Task OnInitializedAsync()
    {
        await using var context = new WarhammerDbContext();
        paints = await context.Paints.Include(x => x.Type).Include(x => x.SubType).ToArrayAsync();
    }

}