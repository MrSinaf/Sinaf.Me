@page "/warhammer/characters/{id:int}"
@using Microsoft.EntityFrameworkCore
@using Sinaf.Me.Data
@using Sinaf.Me.Data.Warhammer

<main>
    @if (character != null)
    {
        <section id="details">
            <span class="sub">Carte de personnage</span>
            <header>
                <div>
                    <h1>@(character?.Name ?? ">Inconnu<")</h1>
                    @if (character!.ClanName != null)
                    {
                        <span>@character.ClanName</span>
                    }
                </div>
                <div>
                    <span>Créé le @character.CreatedAt.ToShortDateString()</span>
                    @if (character.UpdatedAt != null)
                    {
                        <span>Modifié le @character.UpdatedAt?.ToShortDateString()</span>
                    }
                </div>
            </header>
            <section>
                <div id="description">
                    @if (character.Description != null)
                    {
                        <span class="sub">Description</span>
                        <p>@character.Description</p>
                    }
                    <p>@character.Commentary</p>
                </div>
                <div id="stats">
                    <span class="sub">Statistiques</span>
                    <div>
                        <article>
                            <span>Batailles</span>
                            <strong>@character.TotalBattles</strong>
                        </article>
                        <article>
                            <span>Morts</span>
                            <strong>@character.TotalDeaths</strong>
                        </article>
                        <article>
                            <span>Kills participés</span>
                            <strong>@character.TotalKillsParticipating</strong>
                        </article>
                        <article>
                            <span>Kills d'unité</span>
                            <strong>@character.TotalUnitKills</strong>
                        </article>
                        <article>
                            <span>Objectifs</span>
                            <strong>@character.TotalObjectives</strong>
                        </article>
                        <article>
                            <span>Charges ratées</span>
                            <strong>@character.TotalFailedCharges</strong>
                        </article>
                        <article>
                            <span>Sauvegardes impossibles</span>
                            <strong>@character.TotalImpossibleSaves</strong>
                        </article>
                        <article>
                            <span>Dégâts infligés</span>
                            <strong>@character.TotalDamageDone</strong>
                        </article>
                        <article>
                            <span>Dégâts subis</span>
                            <strong>@character.TotalDamageTaken</strong>
                        </article>
                        <article>
                            <span>Dégâts bloqués</span>
                            <strong>@character.TotalDamageBlocked</strong>
                        </article>
                    </div>
                </div>
            </section>
        </section>
        <a href="/warhammer/characters/@(Id).png" target="_blank" id="image">
            <span>#@character.Id</span>
            <img style="margin: -@(character.ThumbnailY)px 0 0 -@(character.ThumbnailX)px;
            scale: @(character.ThumbnailS)%;"
                 src="@character.GetUrlImage()" alt="@character.Name"/>
        </a>
    }
    else
    {
        @if (isLoaded)
        {
            <div>
                <h1>Erreur</h1>
                <p>Aucune données disponible sur un personnage avec l'id @Id /ᐠ｡ꞈ｡ᐟ\...</p>
            </div>
        }
        else
        {
            <p>Chargement...</p>
        }
    }
</main>

@code {

    [Parameter] public int Id { get; set; }

    private CharacterDetail? character;
    private bool isLoaded;

    protected override async Task OnInitializedAsync()
    {
        await using var context = new WarhammerDbContext();
        character = await context.CharacterDetails.FirstOrDefaultAsync(x => x.Id == (uint)Id);
        isLoaded = true;
    }

}